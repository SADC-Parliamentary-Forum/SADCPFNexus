APP_NAME="SADC PF Nexus"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sadcpfnexus
DB_USERNAME=sadcpf
DB_PASSWORD=secret

# RLS runtime role
DB_RLS_ROLE=app_user

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sadcpf.org"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=sadcpfminio
AWS_SECRET_ACCESS_KEY=secret123456
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=sadcpf-documents
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# MinIO root credentials
MINIO_ROOT_USER=sadcpfminio
MINIO_ROOT_PASSWORD=secret123456

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000

# Step-up auth TTL in minutes
STEP_UP_TTL=15

# Classification levels
CLASSIFICATION_LEVELS=UNCLASSIFIED,RESTRICTED,CONFIDENTIAL,SECRET

VITE_APP_NAME="${APP_NAME}"
