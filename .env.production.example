# Root .env — used by docker-compose for variable substitution
# Copy to .env on the VPS and fill in real values

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=https://nexus-api.sadcpf.org
FRONTEND_URL=https://nexus.sadcpf.org

# ── Database ─────────────────────────────────────────────────────────────────
DB_DATABASE=sadcpfnexus
DB_USERNAME=sadcpf
DB_PASSWORD=<change-this-strong-password>

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<change-this-strong-password>
REDIS_PORT=6380

# ── MinIO (file storage) ─────────────────────────────────────────────────────
MINIO_ROOT_USER=sadcpfminio
MINIO_ROOT_PASSWORD=<change-this-strong-password>
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# ── MeiliSearch ──────────────────────────────────────────────────────────────
MEILISEARCH_KEY=<change-this-strong-master-key-min-16-chars>

# ── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_EXPIRATION=1440
SANCTUM_TOKEN_PREFIX=sadcpf_

# ── Web (Next.js) ────────────────────────────────────────────────────────────
# This is baked into the web image at build time — rebuild after changing
NEXT_PUBLIC_API_URL=https://nexus-api.sadcpf.org/api/v1

# ── Ports (keep defaults; nothing public except 80/443 via Caddy) ────────────
WEB_PORT=3000
