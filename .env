# Root env for docker-compose variable substitution.
# Copy to .env: cp env.docker.example .env
# Used by: docker-compose.yml for postgres, redis, web, and api-setup.

DB_DATABASE=sadcpfnexus
DB_USERNAME=sadcpf
DB_PASSWORD=secret
REDIS_PASSWORD=secret
MINIO_ROOT_USER=sadcpfminio
MINIO_ROOT_PASSWORD=secret123456
MEILISEARCH_KEY=masterKey

# Web (Next.js) - API URL as seen by the browser
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
