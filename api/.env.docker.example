# Copy this file to .env when running via Docker: cp .env.docker.example .env
# All values are for docker-compose (postgres, redis, nginx, etc.)

APP_NAME="SADC PF Nexus"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sadcpfnexus
DB_USERNAME=sadcpf
DB_PASSWORD=secret
DB_RLS_ROLE=app_user

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@sadcpf.org"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000

CLASSIFICATION_LEVELS=UNCLASSIFIED,RESTRICTED,CONFIDENTIAL,SECRET
IMPREST_BUDGET_LINES=OP-01,OP-02,CAPEX-01,CAPEX-02
TIMESHEET_PROJECTS=SADCPF-2026-PLN: Annual Planning|SADCPF-2026-GOV: Governance Support|SADCPF-2026-ADM: General Administration|SADCPF-2026-FIN: Finance Operations|SADCPF-2026-ICT: ICT Support
