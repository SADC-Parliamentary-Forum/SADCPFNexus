APP_NAME="SADCPFNexus"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:<generate-with-php-artisan-key-generate>
APP_URL=https://api.yourdomain.com

FRONTEND_URL=https://app.yourdomain.com

# Logging — use warning or error in production (not debug)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Database — use production credentials
DB_CONNECTION=pgsql
DB_HOST=<production-db-host>
DB_PORT=5432
DB_DATABASE=sadcpfnexus
DB_USERNAME=sadcpf
DB_PASSWORD=<strong-random-password>

# Redis (recommended for queue, cache, sessions in production)
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Session — encrypt and secure in production
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# Sanctum token auth
# SANCTUM_EXPIRATION: token lifetime in minutes (1440 = 24h, 480 = 8h)
SANCTUM_EXPIRATION=1440
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com
SANCTUM_TOKEN_PREFIX=sadcpf_

# Password hashing
BCRYPT_ROUNDS=12

# File storage (use S3 or similar in production)
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=<smtp-host>
MAIL_PORT=587
MAIL_USERNAME=<smtp-user>
MAIL_PASSWORD=<smtp-password>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="SADCPFNexus"
