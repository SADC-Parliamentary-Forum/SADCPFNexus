APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email — set MAIL_MAILER=smtp for production and configure SMTP credentials below.
# With MAIL_MAILER=log all emails are written to storage/logs/laravel.log (dev/testing).
# The queue worker (sadcpf_queue container) must be running for emails to be dispatched.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=notifications@sadcpf.org
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="notifications@sadcpf.org"
MAIL_FROM_NAME="SADC-PF Nexus"

# Frontend URL embedded in welcome emails and alert digests
APP_FRONTEND_URL=https://nexus.sadcpf.org

SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# CORS: allowed origin when frontend uses credentials (Next.js, Flutter web, etc.).
# Set to your frontend origin (e.g. http://localhost:3000). After changing this or config/cors.php, run: php artisan config:clear
FRONTEND_URL=http://localhost:3000

VITE_APP_NAME="${APP_NAME}"

# ─── Firebase Cloud Messaging (push notifications) ────────────────────────────
# Generate a Firebase project at https://console.firebase.google.com
# Run `flutterfire configure` in /mobile to generate firebase_options.dart
# Download the service account JSON from Project Settings → Service Accounts
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=   # optional: path to service-account.json
FCM_CLIENT_EMAIL=            # from service account JSON
FCM_PRIVATE_KEY=             # from service account JSON (newlines as \n)
