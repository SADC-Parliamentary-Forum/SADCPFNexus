# ─── Secrets / credentials (NEVER commit) ────────────────────────────────────
*.env
.env
.env.*
!.env.example
!.env.docker.example
api/.env
*.pem
*.key
*.p12
*.pfx
*-firebase-adminsdk-*.json
LOGIN_CREDENTIALS.md

# Tooling configs that may contain personal API keys
.claude/mcp.json
.cursor/mcp.json

# Specific local-only documents
red-team-report.html
docs/security-assessment-report.txt
REMAINING_WORK.md
mobile/DESIGN.md
DOCKER.md

# ─── Build artefacts / dependencies ──────────────────────────────────────────
node_modules/
vendor/
.next/
dist/
build/
out/
coverage/
*.tsbuildinfo

# Vendored / generated PDF helpers
web/public/vendors/

# ─── Laravel runtime caches & ephemeral files ────────────────────────────────
api/bootstrap/cache/*.php
api/storage/app/public/*
!api/storage/app/public/.gitkeep
api/storage/framework/cache/*
!api/storage/framework/cache/.gitignore
api/storage/framework/sessions/*
!api/storage/framework/sessions/.gitignore
api/storage/framework/testing/*
!api/storage/framework/testing/.gitignore
api/storage/framework/views/*
!api/storage/framework/views/.gitignore
api/storage/logs/*.log

# ship-safe scanner state (regenerated on every push, churns timestamps)
api/.ship-safe/context.json
.ship-safe/context.json
.ship-safe/history.json
.ship-safe-backup/

# ─── Flutter / Dart ──────────────────────────────────────────────────────────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.idea/
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/macos/Pods/
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/build/
mobile/android/local.properties
mobile/pubspec.lock
mobile/windows/CMakeLists.txt

# ─── IDE / OS ────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# ─── Binary documents (avoid bloating the repo) ──────────────────────────────
*.pdf
*.docx
*.xlsx
*.pptx

# ─── Misc local scripts ──────────────────────────────────────────────────────
run-tests.sh
